#include<iostream>
using namespace std;
template <typename T>
T multiply( T a , T b)
{
    return a*b;
}
int main()
{
    int i1 , i2;
    float f1 , f2;
    cout <<"value of i1 : ";
    cin>>i1;
    cout <<"value of i2 : ";
    cin>>i2;
    cout <<"value of f1 : ";
    cin>>f1;
    cout <<"value of f2 : ";
    cin>>f2;
    try 
    {
        if (i1<0 ||i2<0)
        {
            throw "the value is negative ";
        }
        cout <<"the multiplication of the integer values is : "<<multiply<int>(i1 , i2)<<endl;
    }
    catch(const char*msg)
    {
        cout <<"exception caught : "<<msg <<endl;
    }
    try 
    {
        if (f1<0 || f2<0)
        {
            throw "the value is negative ";
        }
        cout <<"the multiplication of the floating point is : "<<multiply<float>(f1,f2)<<endl;
    }
    catch (const char*msg)
    {
        cout <<"exception caught : "<<msg <<endl;
    }
    return 0;
}
